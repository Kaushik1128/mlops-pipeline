# =============================================================================
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
#
# Why two files?
#   - `.env.example` is committed → documents what env vars exist
#   - `.env` is gitignored → holds the actual secret values
# A new contributor clones the repo, runs `cp .env.example .env`, and knows
# exactly what they need to set. Without the example file they'd discover
# missing vars one cryptic error at a time.
# =============================================================================

# -----------------------------------------------------------------------------
# MinIO (S3-compatible artifact store)
# These become the root admin credentials for the MinIO server. They are ALSO
# the AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY that MLflow + later boto3 code
# will use to talk to MinIO. Same credentials, two roles.
#
# For local dev these can be anything. In production: long random strings,
# managed by a secrets manager, never in env files at all.
# -----------------------------------------------------------------------------
MINIO_ROOT_USER=mlops_admin
MINIO_ROOT_PASSWORD=change_me_to_something_long

# Default S3 bucket MLflow will write artifacts to. Created on first run.
MLFLOW_ARTIFACT_BUCKET=mlflow-artifacts
DVC_STORAGE_BUCKET=dvc-storage

# -----------------------------------------------------------------------------
# Postgres (MLflow metadata backend)
# -----------------------------------------------------------------------------
POSTGRES_USER=mlflow
POSTGRES_PASSWORD=change_me_too
POSTGRES_DB=mlflow

# -----------------------------------------------------------------------------
# MLflow tracking server
# This is the URL that training code will point at to log runs.
# Inside Docker network: http://mlflow:5000
# From your host machine (browser, local Python): http://localhost:5000
# -----------------------------------------------------------------------------
MLFLOW_TRACKING_URI=http://localhost:5000


# Default: let Git auto-detect (text files normalized to LF in repo)
* text=auto eol=lf

# Force LF for files executed inside Linux containers
*.sh   text eol=lf
*.py   text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf
Dockerfile text eol=lf

# Binary files — never touch
*.png  binary
*.jpg  binary
*.pdf  binary
*.parquet binary
*.pkl  binary
*.pt   binary
*.onnx binary
